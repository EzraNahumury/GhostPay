# Deployer private key (USE A THROWAWAY DEV WALLET — never your main funds).
PRIVATE_KEY=

# RPC endpoints (defaults provided in hardhat.config.ts).
CELO_RPC_URL=https://forno.celo.org
CELO_SEPOLIA_RPC_URL=https://forno.celo-sepolia.celo-testnet.org

# Celoscan API key for contract verification.
CELOSCAN_API_KEY=

# Address that receives LLM usage payments (LlmMeter treasury).
TREASURY_ADDRESS=

# Escrow operator: the backend address allowed to settle/refund LLM escrows.
# Set to your LLM-proxy signer's address (see OPERATOR_PRIVATE_KEY in the frontend .env).
OPERATOR_ADDRESS=

# Accepted pay tokens for LlmMeter (comma-separated stablecoin addresses).
# The user picks which one to pay each LLM call with.
# Celo MAINNET (USDm = the rebranded cUSD contract):
#   USDm 0x765DE816845861e75A25fCA122bb6898B8B1282a  (Mento Dollar, 18 dec)
#   USDC 0xcebA9300f2b948710d2653dD7B07f33A8B32118C  (6 dec)
#   USDT 0x48065fbBE25f71C9282ddf5e1cD6D6A887483D5e  (6 dec)
#   CELO 0x471EcE3750Da237f93B8E339c536989b8978a438  (native, ERC-20, 18 dec)
PAY_TOKENS=0x765DE816845861e75A25fCA122bb6898B8B1282a,0xcebA9300f2b948710d2653dD7B07f33A8B32118C,0x48065fbBE25f71C9282ddf5e1cD6D6A887483D5e,0x471EcE3750Da237f93B8E339c536989b8978a438
