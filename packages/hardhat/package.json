{
  "name": "@ghostpay/hardhat",
  "version": "0.1.0",
  "private": true,
  "description": "GhostPay Solidity contracts for Celo (AgentRegistry, PaymentLog, MemoryVault, Compliance, LlmMeter).",
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "deploy:sepolia": "hardhat run scripts/deploy.ts --network celoSepolia",
    "deploy:celo": "hardhat run scripts/deploy.ts --network celo",
    "verify:sepolia": "hardhat verify --network celoSepolia",
    "verify:celo": "hardhat verify --network celo"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "dotenv": "^16.4.5",
    "hardhat": "^2.22.10",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.4"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^5.0.2"
  }
}
