# GhostPay on Celo — frontend env. Copy to .env.local.

# Network: "celo" (mainnet) or "celoSepolia" (testnet)
NEXT_PUBLIC_CELO_NETWORK=celo
NEXT_PUBLIC_CELO_RPC_URL=https://forno.celo.org
NEXT_PUBLIC_CELO_SEPOLIA_RPC_URL=https://forno.celo-sepolia.celo-testnet.org

# Default stablecoin for payments + LLM metering (USDm | USDC | USDT)
NEXT_PUBLIC_PAY_TOKEN_SYMBOL=USDm

# Public app URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# WalletConnect / Reown project id (for RainbowKit external mobile wallets).
# Free at https://cloud.reown.com — injected/MiniPay works without it.
NEXT_PUBLIC_WC_PROJECT_ID=

# === Deployed contract addresses (from packages/hardhat deploy script) ===
NEXT_PUBLIC_AGENT_REGISTRY=
NEXT_PUBLIC_PAYMENT_LOG=
NEXT_PUBLIC_MEMORY_VAULT=
NEXT_PUBLIC_COMPLIANCE=
NEXT_PUBLIC_LLM_METER=

# === Off-chain services ===
# IPFS pinning (Pinata JWT) — server-side only
PINATA_JWT=
NEXT_PUBLIC_IPFS_GATEWAY=https://gateway.pinata.cloud/ipfs/

# LLM proxy (server-side): any OpenAI-compatible provider for pay-as-you-go AI.
# The app lists the provider's models automatically (/api/models).
#   Ollama Cloud : LLM_API_BASE=https://ollama.com/v1   (key: https://ollama.com/settings/keys)
#   OpenRouter   : LLM_API_BASE=https://openrouter.ai/api/v1
#   Groq         : LLM_API_BASE=https://api.groq.com/openai/v1
LLM_API_KEY=
LLM_API_BASE=https://ollama.com/v1

# Escrow operator key (server-side): settles LlmMeter escrows to treasury on
# success and refunds them on failure. Must match OPERATOR_ADDRESS set on the
# contract. Fund it with a little CELO for gas. If unset, users self-refund
# on-chain after the 15-min timeout instead.
OPERATOR_PRIVATE_KEY=
